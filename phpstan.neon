parameters:
    level: 6
    paths:
        - src
        - tests
    tmpDir: build/phpstan

    ignoreErrors:
        # ✅ Pest: dynamic property access
        - message: '~Access to an undefined property Pest\\Expectation::\$value~'
          path: tests/Pest.php

        # ✅ Pest: closure return type
        - message: '~Parameter #1 \$callback of method Pest\\Expectation::extend\(\) expects callable\(.*\), Closure\(.*\) given~'
          path: tests/Pest.php

        # ✅ Pest: template type covariance in expect()->extend() closure
        - message: '~Anonymous function should return Pest\\Mixins\\Expectation.*but returns Pest\\Mixins\\Expectation~'
          path: tests/Pest.php

        # ✅ Laravel Model toArray covariance
        - message: '~Return type \(array\) of method .+::toArray\(\) should be covariant with return type \(array<string, mixed>\) of method Illuminate\\\\Contracts\\\\Support\\\\Arrayable<string,mixed>::toArray\(\)~'
          path: src/Models/AuthenticationLog.php

        # ✅ Trait analysed in isolation — it is intended for end-user models
        - identifier: trait.unused
          path: src/Traits/NotifiesAuthenticationEvents.php

        # ✅ MorphMany generic in trait — Larastan cannot resolve the static type
        # for polymorphic relationships declared in traits analyzed in test context
        - identifier: missingType.generics
          path: src/Traits/NotifiesAuthenticationEvents.php

        # ✅ Package namespaced views (sentinel-log::location.*) — Larastan cannot
        # resolve vendor view namespaces without the app's view loader being bootstrapped.
        - identifier: argument.type
          path: src/Http/Controllers/LocationVerificationController.php

        # ✅ Pest feature tests — $this in closures is bound to TestCase at runtime
        # but PHPStan infers it as Pest\PendingCalls\TestCall, so custom TestCase
        # methods appear undefined. Global helper functions are used instead.
        - identifier: method.notFound
          path: tests/Feature

        # ✅ Eloquent dynamic properties on test fixture User model
        - identifier: property.notFound
          path: tests/Fixtures/User.php

        # ✅ Pest expect()->and() template type — known Pest/PHPStan interop gap
        - identifier: argument.templateType
          path: tests/Feature

    excludePaths:
        - build

    reportUnmatchedIgnoredErrors: false

includes:
    - ./vendor/larastan/larastan/extension.neon
